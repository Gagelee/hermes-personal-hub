{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/hermes-personal-hub/component.schema.json",
  "title": "Personal Hub Component",
  "type": "object",
  "required": ["id", "type", "status", "title", "source", "data", "placement", "explanation"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "data": {
      "type": "object",
      "required": ["file"],
      "additionalProperties": true,
      "properties": {
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "placement": {
      "type": "object",
      "required": ["semantic_zone"],
      "additionalProperties": true,
      "properties": {
        "preferred_surface": { "type": "string" },
        "semantic_zone": { "type": "string", "minLength": 1 },
        "priority": { "type": "number" }
      }
    },
    "adaptation": {
      "type": "object",
      "additionalProperties": true
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": true
    },
    "promotion": {
      "type": "object",
      "additionalProperties": true
    },
    "explanation": {
      "type": "object",
      "required": ["why_here", "user_value"],
      "additionalProperties": true,
      "properties": {
        "why_here": { "type": "string", "minLength": 1 },
        "user_value": { "type": "string", "minLength": 1 }
      }
    }
  }
}
