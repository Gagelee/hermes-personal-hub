{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/hermes-personal-hub/growth-signal.schema.json",
  "title": "Personal Hub Growth Signal",
  "type": "object",
  "required": ["id", "kind", "source", "observed_at", "summary", "evidence", "confidence", "privacy"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "observed_at": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "candidate_world": { "type": "string" },
    "suggested_track": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "privacy": { "type": "string", "minLength": 1 }
  }
}
