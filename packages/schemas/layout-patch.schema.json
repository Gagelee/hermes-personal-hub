{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/hermes-personal-hub/layout-patch.schema.json",
  "title": "Personal Hub Layout Patch",
  "type": "object",
  "required": ["id", "created_at", "risk_level", "operations", "rollback"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "risk_level": { "type": "integer", "minimum": 0 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "additionalProperties": true,
        "properties": {
          "op": { "type": "string", "minLength": 1 },
          "component_id": { "type": "string" },
          "target": { "type": "object" }
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["strategy", "operations"],
      "additionalProperties": true,
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["op"],
            "additionalProperties": true,
            "properties": {
              "op": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
