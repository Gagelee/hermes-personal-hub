{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/hermes-personal-hub/page.schema.json",
  "title": "Personal Hub Page",
  "type": "object",
  "required": ["id", "title", "status", "semantic_zone", "components"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "semantic_zone": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "components": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "data_sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "auto_layout": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
